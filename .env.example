# Docker Compose configuration — copy to .env and fill in real values.
# Both values are required; compose refuses to start without them.

DB_PASSWORD=change_me
API_KEY=change_me

# Optional overrides
#DB_NAME=onecloudsync
#DB_USER=postgres
#CORS_ORIGIN=http://localhost:8080

# Network binding (Tailscale hardening)
# BIND_IP=0.0.0.0 (default) exposes the app on all interfaces, including LAN.
# Set it to your Tailscale IP (run: tailscale ip -4) so ONLY devices on your
# tailnet can reach the app:
#BIND_IP=100.x.x.x
#BIND_PORT=8080
